# grant_type=client_credentials. Authorization=Basic(client_id:client_secret). Body: username, password from login form. scope=market
VITE_OAUTH_TOKEN_URL=https://idxd.de/m/oauth2/token
VITE_OAUTH_CLIENT_ID=your_client_id
VITE_OAUTH_CLIENT_SECRET=your_client_secret
VITE_OAUTH_SCOPE=market

# ---------------------------------------------------------------------------
# OIDC (login with password / OpenID Connect).
# Local `npm run dev` defaults: issuer https://localhost:5001 (Vite proxies /api-identity there).
# Run Imriva.Identity.Host first. API appsettings.Development.json: Jwt:Authority = https://localhost:5001,
# Jwt:Audience = api (or match your Identity resource name).
# Optional overrides:
#   VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback   (default in dev)
# Use hosted dev auth instead of local Identity:
#   VITE_OIDC_ISSUER=https://dev.auth.vdpconnect.idxd.de
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Local development – frontend, backend API, and Identity on localhost
# Copy to .env or .env.local only if you need non-defaults. Run: Identity → API → Frontend.
# ---------------------------------------------------------------------------
# Identity (auth): https://localhost:5001  (Imriva.Identity.Host; default when VITE_OIDC_ISSUER unset in dev)
# VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
# Backend API: http://localhost:5225  (Imriva.VdpConnect.Api, profile "http"; Vite proxy default)
# VITE_API_BASE_URL=http://localhost:5225
# ---------------------------------------------------------------------------

# Backend API base URL (no trailing slash). If unset in dev, defaults to http://localhost:5225.
# VITE_API_BASE_URL=https://localhost:7166
# VITE_OIDC_ISSUER=https://dev.auth.vdpconnect.idxd.de
# VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...
# VITE_APPINSIGHTS_CLOUD_ROLE=vdpconnect-frontend-dev

# ---------------------------------------------------------------------------
# E2E (Playwright) â€“ only needed when running backend-dependent tests
# ---------------------------------------------------------------------------
# Set to 1 to enable backend-dependent E2E tests
# E2E_BACKEND=1
# Valid test user credentials (do not commit real credentials)
# E2E_USER_EMAIL="user@example.com"
# E2E_USER_PASSWORD="your_test_password"
# E2E_PLATFORM_ADMIN_EMAIL="platform-admin@example.com"
# E2E_PLATFORM_ADMIN_PASSWORD="your_platform_admin_password"
# E2E_PARTNER_ADMIN_EMAIL="partner-org-admin@example.com"
# E2E_PARTNER_ADMIN_PASSWORD="your_partner_org_admin_password"
# Optional when dev has no discoverable managed org for the partner-admin user:
# E2E_PARTNER_MANAGE_PATH="/partners/{partner-guid}/manage"
